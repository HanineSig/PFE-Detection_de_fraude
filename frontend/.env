# Configuration de l'environnement Frontend

# Informations sur l'application
VITE_APP_NAME="CIAR Fraud Detection"
VITE_APP_VERSION="1.0.0"

# Mode Mock (Bouchon)
# Si "true", l'application utilisera les donnees fictives locales.
# Si "false", l'application effectuera des requetes reelles vers le backend.
VITE_USE_MOCK="true"

# URL de l'API Backend
# L'adresse ou le backend FastAPI est heberge (par defaut http://localhost:8000)
VITE_API_URL="http://localhost:8000/api"
