# Configuration de l'environnement Backend

# Informations generales
PROJECT_NAME="CIAR Fraud Detection API"
VERSION="1.0.0"
API_PREFIX="/api"

# Configuration de la base de donnees (PostgreSQL pour le developpement local)
# Format attendu : postgresql://utilisateur:mot_de_passe@hote:port/nom_base_de_donnees
DATABASE_URL="postgresql://postgres.xnzwuvjgyjyydytrcpvd:SarahHanine66@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Securite et Authentication JWT
# AVERTISSEMENT : En mode production, utiliser une clef longue, aleatoire et secrete.
SECRET_KEY="clef_secrete_provisoire_de_developpement_ciar_pfe"
ALGORITHM="HS256"
# La duree de validite du token en minutes (ex: 480 minutes correspond a 8 heures de travail).
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Configuration CORS (Ressources multi-origines)
# Liste des origines autorisees a communiquer avec cette API (le frontend local par defaut).
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
